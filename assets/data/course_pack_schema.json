{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LingoNexa Course Pack",
  "type": "object",
  "required": ["version", "language", "units"],
  "properties": {
    "version": {"type": "integer", "minimum": 1},
    "language": {"type": "string", "minLength": 2},
    "region": {"type": "string"},
    "units": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "cefr", "title", "lessons"],
        "properties": {
          "id": {"type": "string"},
          "cefr": {"enum": ["A1", "A2", "B1", "B2", "C1", "C2"]},
          "title": {"type": "string"},
          "lessons": {"type": "array"}
        }
      }
    }
  }
}

